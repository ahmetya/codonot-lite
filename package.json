{
  "name": "codonot-lite",
  "version": "1.0.0",
  "scripts": {
    "dev": "concurrently \"npm run restart:server\" \"npm run dev --prefix client\"",
    "restart:server": "node scripts/free-port.cjs 3001 && npm run dev --prefix server",
    "stop:server": "node scripts/free-port.cjs 3001",
    "start:server": "npm run start --prefix server",
    "start:client": "npm run dev --prefix client"
  },
  "devDependencies": {
    "concurrently": "^8.0.0",
    "eslint": "^10.3.0",
    "prettier-plugin-env": "^0.4.3",
    "prettier-plugin-prisma": "^5.0.0"
  }
}
